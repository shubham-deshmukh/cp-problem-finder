# ==========================================
# Meilisearch Database Configuration
# ==========================================
# The URL where Meilisearch is running (use http://meilisearch:7700 if using docker-compose)
MEILI_URL="http://127.0.0.1:7700"
# Must be at least 16 bytes/characters long for Meilisearch v1.7+
MEILI_MASTER_KEY="your_meilisearch_master_key_here"
INDEX_NAME="dsa_problems"

# ==========================================
# Google OAuth 2.0 Configuration
# ==========================================
# Client credentials from Google Cloud Console APIs & Services
GOOGLE_CLIENT_ID="your_google_client_id_here.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"
# The callback URL authorized in your Google Cloud Console redirect URIs
GOOGLE_REDIRECT_URI="http://localhost:5173/auth/callback"

# ==========================================
# JWT Authentication Configuration
# ==========================================
# A strong, high-entropy secret key used to sign JWT session cookies
JWT_SECRET="your_jwt_signing_secret_here"
# Algorithm to sign tokens (e.g. HS256)
JWT_ALGORITHM="HS256"
# Validity window of session tokens and cookies in minutes
JWT_EXPIRATION_MINUTES=10

# ==========================================
# Application / Frontend Configuration
# ==========================================
# URL where your frontend client is running (used for CORS mapping and auth redirect fallbacks)
FRONTEND_URL="http://localhost:5173"
# Comma-separated list of administrative emails authorized for CRUD write operations
ADMIN_EMAILS="admin@example.com,user2@example.com"